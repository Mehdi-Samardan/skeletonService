# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/?retryWrites=true&w=majority

# Name of the MongoDB database to use
DATABASE_NAME=skeleton_db

# GroupDocs Cloud API credentials
# Sign up at https://dashboard.groupdocs.cloud to get these
GROUPDOCS_CLIENT_ID=your-groupdocs-client-id
GROUPDOCS_CLIENT_SECRET=your-groupdocs-client-secret

# JWT Secret
JWT_SECRET=your_jwt_secret_key